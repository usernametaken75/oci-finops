# OCI Configuration
OCI_TENANCY_OCID=ocid1.tenancy.oc1..exampleuniqueID
OCI_REGION=us-ashburn-1
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=oci_finops
PG_USER=finops
PG_PASSWORD=changeme

# ETL Settings
ETL_BATCH_SIZE=10000
ETL_TEMP_DIR=/tmp/oci-finops
FOCUS_REPORT_YEAR=2026

# Anomaly Detection
ANOMALY_ROLLING_WINDOW_DAYS=30
ANOMALY_STDDEV_THRESHOLD=3.0
ANOMALY_ML_CONTAMINATION=0.05

# Notifications (optional)
ONS_TOPIC_OCID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=finops-alerts@example.com
SMTP_TO=team@example.com

# Grafana
GRAFANA_ADMIN_PASSWORD=admin
